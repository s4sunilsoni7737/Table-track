APP_NAME=TableTrack
APP_KEY=

# Do not change APP_ENV to anything else. It will affect emailing from admin panel
# and other configuration from database and system may crash
APP_ENV=codecanyon
APP_DEBUG=false

APP_URL=https://your-domain.com

# Main application subdomain if subdomain is installed on subdomain
MAIN_APPLICATION_SUBDOMAIN=

#For redirect to https
REDIRECT_HTTPS=true

# -----------------------------------------------------------------------
# Database – AWS RDS MySQL
# -----------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_DATABASE=tabletrack
DB_USERNAME=tabletrack_user
DB_PASSWORD=
# Path to RDS CA bundle (download from https://truststore.pki.rds.amazonaws.com/)
# Leave empty if you are NOT using SSL (not recommended for production)
DB_SSL_CA=

# -----------------------------------------------------------------------
# Cache / Queue
# -----------------------------------------------------------------------
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# -----------------------------------------------------------------------
# Mail (e.g. AWS SES, Mailgun, etc.)
# -----------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="TableTrack"

# -----------------------------------------------------------------------
# AWS S3 – File Storage & CDN
# -----------------------------------------------------------------------
# IAM user credentials (use IAM Role in production instead of keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# S3 bucket for user-uploaded files (restaurant menus, logos, etc.)
AWS_BUCKET=
FILESYSTEM_DISK=local

# S3 bucket for Vite build assets (optional CDN)
CDN_ENABLED=false
AWS_BUCKET_BUILD=
AWS_BUCKET_BUILD_FOLDER=
CDN_URL=
AWS_URL=

# -----------------------------------------------------------------------
# Broadcasting / Pusher (optional, for real-time features)
# -----------------------------------------------------------------------
BROADCAST_DRIVER=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=

# -----------------------------------------------------------------------
# Payment Gateways (configure only those you use)
# -----------------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=

# Set to true once migrations have run on first deploy
RUN_MIGRATIONS=true
